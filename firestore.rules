rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Extern AI platform users ──────────────────────────────────────────
    // Users can read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Integration credentials - users can read/write their own credentials
    match /integrationCredentials/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Published apps metadata - publicly readable, write via Cloud Functions
    match /publishedApps/{appId} {
      allow read: if true;
      allow write: if false; // Only Cloud Functions can write
    }

    // Conversation history - users can read/write their own conversations
    match /conversations/{userId}/{conversationId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Generated App Infrastructure ──────────────────────────────────────
    // Tenant registry — readable by any authenticated Extern AI user, writable only by backend
    match /generatedAppTenants/{appId} {
      allow read: if request.auth != null;
      allow write: if false; // Backend service account only
    }

    // Each generated app gets its own tenant space.
    // End-users of generated apps can only see their own usage record.
    match /generatedAppUsers/{appId}/users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // RAG document metadata - only authenticated users of that app can read
    // Write is handled exclusively by the backend (service account)
    match /generatedAppDocuments/{appId}/docs/{docId} {
      allow read: if request.auth != null;
      allow write: if false; // Backend service account only
    }

    // RAG document chunks with embeddings
    // Only readable by authenticated users; written only by backend
    match /generatedAppDocuments/{appId}/docs/{docId}/chunks/{chunkId} {
      allow read: if request.auth != null;
      allow write: if false; // Backend service account only
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
